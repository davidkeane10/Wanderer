rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Community spots ────────────────────────────────────────────────────
    match /community_spots/{spotId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000;
      allow update: if request.auth != null
        && resource.data.submittedBy == request.auth.uid
        && request.resource.data.submittedBy == resource.data.submittedBy;
      allow delete: if request.auth != null
        && resource.data.submittedBy == request.auth.uid;
    }

    // ── Groups ─────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      // Any signed-in user can read — required so non-members can resolve
      // a group after looking up an invite code (join flow).
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 50;

      allow update: if request.auth != null && (
        // Existing members can update the group (add spots, vote, etc.)
        request.auth.uid in resource.data.memberIds
        ||
        // Non-members may only add themselves via a valid join code
        isValidSelfJoin()
      );

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // ── Invite codes ───────────────────────────────────────────────────────
    match /inviteCodes/{code} {
      // Any signed-in user can look up a code to join a group.
      allow read: if request.auth != null;

      // Only the group creator can register a code.
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.createdBy == request.auth.uid;

      // Only the group creator can remove a code.
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.createdBy == request.auth.uid;

      allow update: if false;
    }

    // ── Helper functions ───────────────────────────────────────────────────
    function isValidSelfJoin() {
      let existing = resource.data;
      let incoming = request.resource.data;
      return !(request.auth.uid in existing.memberIds)
        && request.auth.uid in incoming.memberIds
        && incoming.memberIds.hasAll(existing.memberIds)
        && incoming.memberIds.size() == existing.memberIds.size() + 1
        && incoming.diff(existing).affectedKeys().hasOnly(['memberIds', 'members']);
    }
  }
}
