rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — readable by anyone signed in, writable only by owner
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Community spots — anyone signed in can submit; read is public
    match /community_spots/{spotId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.submittedBy;
    }

    // Groups — members-only read/write enforced in app logic + here
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    match /inviteCodes/{code} {
      allow read, write: if request.auth != null;
    }
  }
}
